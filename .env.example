OPENAI_API_KEY=
ESTATIA_APP_NAME=Estatia
ESTATIA_FAST_MODEL=gpt-5-nano
ESTATIA_QUALITY_MODEL=gpt-5-mini
ESTATIA_LOG_LEVEL=INFO
ESTATIA_LISTING_MODE=playwright
ESTATIA_BROWSER_HEADLESS=true
ESTATIA_SCRAPE_TIMEOUT_MS=20000
ESTATIA_SEARCH_RESULTS_LIMIT=5
ESTATIA_ENABLE_SEED_FALLBACK=true
ESTATIA_EVALUATION_THRESHOLD=0.72
ESTATIA_MAX_RETRIES=1
ESTATIA_ENABLE_NEWS_AGENT=true
ESTATIA_ENABLE_WHATSAPP_AGENT=false
